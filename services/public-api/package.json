{
  "name": "funded-public-api",
  "version": "1.0.0",
  "private": true,
  "description": "FundEd Public REST API & Webhook delivery service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate": "psql $DATABASE_URL -f db/schema.sql"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "rate-limit-redis": "^4.2.0",
    "ioredis": "^5.4.1",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.5.0",
    "pg": "^8.12.0",
    "axios": "^1.7.4",
    "zod": "^3.23.8",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/pg": "^8.11.6",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
