# Public API service environment

# HTTP
PORT=4000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/funded_public

# Redis (opsiyonel — yoksa rate limit in-memory)
# REDIS_URL=redis://localhost:6379

# Admin endpoint'lerini açar — set edilmezse /admin/* 503 döner.
ADMIN_API_TOKEN=change-me-to-a-long-random-secret

# Worker tuning
WORKER_TICK_MS=5000
WORKER_BATCH_SIZE=50

# Logging
NODE_ENV=development
LOG_LEVEL=info
