{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "fund-ed.com"
        }
      ],
      "destination": "https://www.fund-ed.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/exchange-rate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/process-subscriptions",
      "schedule": "0 9 * * *"
    }
  ]
}